<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Perlocalc" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
      .news-ticker {
        background-color: #f8f9fa;
        border-bottom: 1px solid #dee2e6;
        padding: 10px 0;
        overflow: hidden;
        white-space: nowrap;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
      }
      .ticker-content {
        display: inline-block;
        animation: ticker 30s linear infinite;
      }
      @keyframes ticker {
        0% { transform: translateX(100%); }
        100% { transform: translateX(-100%); }
      }
      body {
        padding-top: 50px;
      }
      .sql-section {
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        padding: 20px;
        margin-top: 30px;
      }
      .sql-query {
        background-color: #f1f1f1;
        padding: 10px;
        border-radius: 4px;
        margin-bottom: 10px;
        font-family: monospace;
        white-space: pre-wrap;
      }
      .sql-results {
        background-color: #e9ecef;
        padding: 15px;
        border-radius: 4px;
        margin-top: 20px;
      }
      .result-item {
        margin-bottom: 10px;
        padding: 10px;
        border-radius: 4px;
      }
      .result-item.correct {
        background-color: #d4edda;
        border: 1px solid #c3e6cb;
      }
      .result-item.incorrect {
        background-color: #f8d7da;
        border: 1px solid #f5c6cb;
      }
    </style>
  </head>

  <body>
    <div id="news-ticker" class="news-ticker">
      <div class="ticker-content">
        Connecting to API validation service...
      </div>
    </div>

    <div class="container mt-4">
      <% if notice %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>
      
      <%= yield %>

      <div class="sql-section">
        <h3>SQL Queries and Results</h3>
        
        <h5>Table Creation and Data Insertion:</h5>
        <div class="sql-query">
CREATE TABLE orders (
    id INTEGER PRIMARY KEY,
    customer TEXT,
    amount REAL,
    order_date DATE
);

INSERT INTO orders (customer, amount, order_date) VALUES
('Alice', 5000, '2024-03-01'),
('Bob', 8000, '2024-03-05'),
('Alice', 3000, '2024-03-15'),
('Charlie', 7000, '2024-02-20'),
('Alice', 10000, '2024-02-28'),
('Bob', 4000, '2024-02-10'),
('Charlie', 9000, '2024-03-22'),
('Alice', 2000, '2024-03-30');
        </div>

        <h5>Analysis Queries:</h5>
        <div class="sql-query">
-- Total sales for March
SELECT SUM(amount) as total_march_sales
FROM orders
WHERE strftime('%m', order_date) = '03';

-- Top-spending customer
SELECT customer, SUM(amount) as total_spent
FROM orders
GROUP BY customer
ORDER BY total_spent DESC
LIMIT 1;

-- Average order value
SELECT AVG(amount) as avg_order_value
FROM orders;
        </div>

        <div class="sql-results">
          <h5>Expected Results:</h5>
          <ul>
            <li>Total sales for March: 27,000</li>
            <li>Top-spending customer: Alice (20,000)</li>
            <li>Average order value: 6,000</li>
          </ul>
        </div>

        <div id="current-results" class="sql-results">
          <h5>Current Results:</h5>
          <div id="march-sales" class="result-item">
            <strong>Total sales for March:</strong> <span class="value">Loading...</span>
          </div>
          <div id="top-customer" class="result-item">
            <strong>Top-spending customer:</strong> <span class="value">Loading...</span>
          </div>
          <div id="avg-order" class="result-item">
            <strong>Average order value:</strong> <span class="value">Loading...</span>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
      // Wait for DOM to be fully loaded
      document.addEventListener('DOMContentLoaded', function() {
        console.log('DOM loaded, initializing ticker...');
        const tickerContent = document.querySelector('.ticker-content');
        
        function updateTicker() {
          console.log('Making API request...');
          fetch('https://fakestoreapi.com/products')
            .then(response => {
              console.log('API response received:', response.status);
              const status = response.status;
              return response.json().then(products => ({ status, products }));
            })
            .then(({ status, products }) => {
              console.log('Processing products:', products.length);
              const defects = [];
              const totalProducts = products.length;
              
              products.forEach(product => {
                // Check title
                if (!product.title || product.title.trim() === '') {
                  defects.push(`Product ID ${product.id}: Empty title`);
                }
                
                // Check price
                if (product.price < 0) {
                  defects.push(`Product ID ${product.id}: Negative price`);
                }
                
                // Check rating
                if (product.rating && product.rating.rate > 5) {
                  defects.push(`Product ID ${product.id}: Rating exceeds 5`);
                }
              });
              
              let content = `API Status: ${status} | ` +
                           `Total Products: ${totalProducts} | ` +
                           `Defects Found: ${defects.length} | ` +
                           `Last Checked: ${new Date().toLocaleTimeString()}`;
              
              if (defects.length > 0) {
                content += ` | Defects: ${defects.join(' | ')}`;
              }
              
              tickerContent.textContent = content;
              console.log('Ticker updated with new content');
            })
            .catch(error => {
              console.error('API request failed:', error);
              tickerContent.textContent = `Error: ${error.message}`;
            });
        }

        function updateSqlResults() {
          fetch('/sql_results')
            .then(response => response.json())
            .then(data => {
              // Update March sales
              const marchSales = document.getElementById('march-sales');
              const marchValue = data.march_sales;
              marchSales.querySelector('.value').textContent = marchValue.toLocaleString();
              marchSales.className = `result-item ${marchValue === 27000 ? 'correct' : 'incorrect'}`;

              // Update top customer
              const topCustomer = document.getElementById('top-customer');
              const [customer, amount] = data.top_customer;
              topCustomer.querySelector('.value').textContent = `${customer} (${amount.toLocaleString()})`;
              topCustomer.className = `result-item ${customer === 'Alice' && amount === 20000 ? 'correct' : 'incorrect'}`;

              // Update average order
              const avgOrder = document.getElementById('avg-order');
              const avgValue = Math.round(data.avg_order);
              avgOrder.querySelector('.value').textContent = avgValue.toLocaleString();
              avgOrder.className = `result-item ${avgValue === 6000 ? 'correct' : 'incorrect'}`;
            })
            .catch(error => {
              console.error('Failed to fetch SQL results:', error);
            });
        }
        
        // Initial updates
        console.log('Starting initial updates...');
        updateTicker();
        updateSqlResults();
        
        // Set up intervals
        console.log('Setting up intervals...');
        setInterval(updateTicker, 5000);
        setInterval(updateSqlResults, 10000);
      });
    </script>
  </body>
</html>
