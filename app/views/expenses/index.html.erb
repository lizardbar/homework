<div class="row mb-4">
  <div class="col">
    <h1>Monthly Expenses</h1>
    <%= link_to 'Add New Expense', new_expense_path, class: 'btn btn-primary' %>
  </div>
</div>

<div class="row mb-4">
  <div class="col-md-4">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title">Total Expenses</h5>
        <p class="card-text display-4">$<%= number_with_precision(@total_amount, precision: 2) %></p>
      </div>
    </div>
  </div>
  
  <div class="col-md-4">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title">Average Daily Expense</h5>
        <p class="card-text display-4">$<%= number_with_precision(@average_daily, precision: 2) %></p>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title">Month</h5>
        <p class="card-text display-4"><%= @current_date.strftime('%B %Y') %></p>
      </div>
    </div>
  </div>
</div>

<div class="row mb-4">
  <div class="col-md-6">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title">Top 3 Expenses</h5>
        <ul class="list-group">
          <% @top_expenses.each do |expense| %>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <%= expense.description %>
              <span class="badge bg-primary rounded-pill">$<%= number_with_precision(expense.amount, precision: 2) %></span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title">All Expenses</h5>
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Description</th>
                <th>Amount</th>
              </tr>
            </thead>
            <tbody>
              <% @expenses.order(date: :desc).each do |expense| %>
                <tr>
                  <td><%= expense.date.strftime('%Y-%m-%d') %></td>
                  <td><%= expense.description %></td>
                  <td>$<%= number_with_precision(expense.amount, precision: 2) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col">
    <div class="btn-group">
      <%= link_to 'Previous Month', 
          expenses_path(date: @current_date.prev_month), 
          class: 'btn btn-outline-primary' %>
      <%= link_to 'Next Month', 
          expenses_path(date: @current_date.next_month), 
          class: 'btn btn-outline-primary' %>
    </div>
  </div>
</div>
