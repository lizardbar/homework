<h1>Expenses#new</h1>
<p>Find me in app/views/expenses/new.html.erb</p>

<div class="row">
  <div class="col-md-6 offset-md-3">
    <div class="card">
      <div class="card-body">
        <h2 class="card-title">New Expense</h2>

        <%= form_with(model: @expense, local: true) do |f| %>
          <% if @expense.errors.any? %>
            <div class="alert alert-danger">
              <h4><%= pluralize(@expense.errors.count, "error") %> prohibited this expense from being saved:</h4>
              <ul>
                <% @expense.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.label :description, class: 'form-label' %>
            <%= f.text_field :description, class: 'form-control' %>
          </div>

          <div class="mb-3">
            <%= f.label :amount, class: 'form-label' %>
            <%= f.number_field :amount, class: 'form-control', step: '0.01' %>
          </div>

          <div class="mb-3">
            <%= f.label :date, class: 'form-label' %>
            <%= f.date_field :date, class: 'form-control' %>
          </div>

          <div class="d-grid gap-2">
            <%= f.submit 'Create Expense', class: 'btn btn-primary' %>
            <%= link_to 'Back to Expenses', expenses_path, class: 'btn btn-outline-secondary' %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
